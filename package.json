{
  "name": "cognito-toolkit",
  "version": "2.0.0",
  "description": "Zero-dependency toolkit to validate AWS Cognito JWTs (id / access tokens) for authentication & authorization in web apps.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./utils/lazy-access-token": "./src/utils/lazy-access-token.js",
    "./utils/renewable-access-token": "./src/utils/renewable-access-token.js",
    "./*": "./src/*"
  },
  "scripts": {
    "test": "tape6 --flags FO",
    "test:bun": "tape6-bun --flags FO",
    "test:deno": "tape6-deno --flags FO",
    "ts-test": "tape6 --flags FO tests/test-*.*ts",
    "ts-check": "tsc --noEmit",
    "js-check": "tsc --project tsconfig.check.json",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write ."
  },
  "tape6": {
    "tests": [
      "/tests/test-*.js",
      "/tests/test-*.mjs"
    ],
    "node": [
      "/tests/test-*.cjs"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhop/cognito-toolkit.git"
  },
  "keywords": [
    "aws",
    "cognito",
    "authentication",
    "authorization",
    "jwt",
    "jwks",
    "oauth2",
    "user-pool",
    "esm",
    "zero-dependencies"
  ],
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com> (http://lazutkin.com)",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/uhop/cognito-toolkit/issues"
  },
  "homepage": "https://github.com/uhop/cognito-toolkit#readme",
  "funding": "https://github.com/sponsors/uhop",
  "llms": "https://raw.githubusercontent.com/uhop/cognito-toolkit/master/llms.txt",
  "llmsFull": "https://raw.githubusercontent.com/uhop/cognito-toolkit/master/llms-full.txt",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "prettier": "^3.9.1",
    "tape-six": "^1.11.0",
    "typescript": "^7.0.2"
  },
  "files": [
    "src",
    "llms.txt",
    "llms-full.txt"
  ]
}
